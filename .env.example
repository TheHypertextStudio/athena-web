# Docket — environment contract (single source: packages/env/src/registry.ts).
#
# Copy to `.env.local` for local dev, then fill in values. Every var below is REQUIRED
# unless explicitly marked optional — the schema has no hidden defaults, so a missing
# value fails fast rather than silently using a guessed one. With APP_MODE=local and
# placeholder external keys, Docket runs the FULL product against mock boundary adapters,
# so no external accounts are required. `pnpm dev` starts the local Postgres in Docker.
# Run `pnpm env:check` to validate.
#
# NOTE: NODE_ENV is intentionally NOT listed — it is framework/runtime-managed
# (`next dev` → development, `next build` → production) and must not be set here.

# ── Shared ────────────────────────────────────────────────────────────────────
# local | test | production — local/test force the mock boundary adapters.
APP_MODE=local
# Origin the web/admin apps proxy /v1 + /api/auth to (the API). Portless named URL.
API_URL=https://api.docket.localhost
# API listen port (required by the contract). In dev, portless assigns an ephemeral
# port and overrides this; the value here is the fallback for non-portless runs.
PORT=4000

# ── Database (required) ─────────────────────────────────────────────────────────
# Driver is chosen from the URL scheme: pglite: | postgres: | neon:
#   local dev : postgres://docket:docket@localhost:5433/docket  (Docker; `pnpm db:up`)
#   zero-svc  : pglite://.data/docket   (embedded, in-process — no Docker)
#   prod      : the Neon pooled URL
DATABASE_URL=postgres://docket:docket@localhost:5433/docket
# Unpooled string used for migrations (optional; falls back to DATABASE_URL).
DATABASE_URL_UNPOOLED=

# ── Auth (BETTER_AUTH_SECRET required, ≥32 chars: openssl rand -base64 32) ───────
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-min-32-chars
BETTER_AUTH_URL=https://api.docket.localhost
BETTER_AUTH_TRUSTED_ORIGINS=https://web.docket.localhost,https://admin.docket.localhost,https://marketing.docket.localhost
BETTER_AUTH_PASSKEY_RP_ID=docket.localhost
BETTER_AUTH_PASSKEY_RP_NAME=Docket
# Social providers (optional) — absent/placeholder ⇒ provider is not mounted, UI hides it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# ── Billing (Stripe) — BILLING_ENABLED required; =true also needs the key + a price ──
# Empty/placeholder values keep the mock InMemoryBillingGateway; supplying a real
# STRIPE_SECRET_KEY (outside APP_MODE=local/test) selects RealStripeGateway. The gateway
# resolves a DOCKET_PRICE_LOOKUP_* lookup key (or a STRIPE_PRICE_TEAM price id) to the
# price, runs the 14-day trial, and verifies webhooks with STRIPE_WEBHOOK_SECRET.
# Embedded Checkout is the default flow (rendered via NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY).
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
DOCKET_PRICE_LOOKUP_TEAM=
DOCKET_PRICE_LOOKUP_TEAM_ANNUAL=
STRIPE_PRICE_TEAM=
STRIPE_BILLING_PORTAL_CONFIG_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── MCP remote server (MCP_TASKS_ENABLED + MCP_CIMD_STRICT required) ──────────────
MCP_ISSUER_URL=
MCP_RESOURCE_URL=
MCP_ALLOWED_ORIGINS=
OIDC_LOGIN_PAGE_URL=
MCP_TASKS_ENABLED=false
MCP_CIMD_TRUST_ALLOWLIST=
MCP_CIMD_STRICT=true
MCP_SESSION_STORE_URL=

# ── Agent runtime (optional) ──────────────────────────────────────────────────────
# The built-in Athena runtime drives a real Claude turn via the Anthropic Messages API.
# Set ANTHROPIC_API_KEY to a real key (sk-ant-...) to select RealProviderRuntime in prod;
# blank/placeholder keeps the deterministic MockAgentRuntime (and local/test always mock).
ANTHROPIC_API_KEY=

# ── Ops ──────────────────────────────────────────────────────────────────────────
CRON_SECRET=dev-cron-secret-please-change-me
SENTRY_DSN=
BLOB_READ_WRITE_TOKEN=
# Export bucket URL + token are all-or-nothing (optional).
EXPORT_BUCKET_URL=
EXPORT_BUCKET_TOKEN=

# ── Transactional email (SMTP) ────────────────────────────────────────────────────
# SmtpMailer (nodemailer). Absent/blank SMTP_HOST or MAIL_FROM ⇒ mock CaptureMailer.
#   local : SMTP_HOST=localhost SMTP_PORT=1025 (Mailpit; no auth) MAIL_FROM="Docket <dev@docket.localhost>"
#   prod  : your relay host/port + SMTP_USER/SMTP_PASS, SMTP_SECURE=true on port 465.
# SMTP_PORT defaults to 587 (STARTTLS); SMTP_SECURE defaults to true only on port 465.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ── Connectors (GitHub / Linear / Drive / Gmail / Calendar) ─────────────────────────
# RealConnector talks to each provider's API with a per-connection OAuth token / API key
# supplied from the stored credential (NOT from env). These optional variables only
# override the provider API base for self-hosted / non-public hosts (e.g. GitHub
# Enterprise); blank ⇒ the provider's public API base is used.
GITHUB_API_BASE=
LINEAR_API_BASE=
GOOGLE_DRIVE_API_BASE=
GOOGLE_GMAIL_API_BASE=
GOOGLE_CALENDAR_API_BASE=

# ── Public (browser; Next inlines these literally) ───────────────────────────────
NEXT_PUBLIC_API_URL=https://api.docket.localhost
NEXT_PUBLIC_APP_URL=https://web.docket.localhost
# Deploy mode echoed to the browser. `local` ⇒ the mock boundary adapters back every
# connector, so onboarding offers all sources live (no OAuth needed). In prod, leave this
# unset (or `production`) and gate each connector with its NEXT_PUBLIC_CONNECTOR_* flag.
NEXT_PUBLIC_APP_MODE=local
# Per-connector availability for prod onboarding: set to a truthy value only once that
# provider's OAuth is wired, so the connect step never renders a dead button. Ignored when
# NEXT_PUBLIC_APP_MODE=local (the mock backs everything in dev).
NEXT_PUBLIC_CONNECTOR_CALENDAR=
NEXT_PUBLIC_CONNECTOR_GTASKS=
NEXT_PUBLIC_CONNECTOR_LINEAR=
