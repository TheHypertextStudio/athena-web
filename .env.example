# Docket — environment contract (single source: packages/env/src/registry.ts).
#
# Copy to `.env.local` for local dev, then fill in values. Every var below is REQUIRED
# unless explicitly marked optional — the schema has no hidden defaults, so a missing
# value fails fast rather than silently using a guessed one. With APP_MODE=local and
# placeholder external keys, Docket runs the FULL product against mock boundary adapters,
# so no external accounts are required. `pnpm dev` starts the local Postgres in Docker.
# Run `pnpm env:check` to validate.
#
# NOTE: NODE_ENV is intentionally NOT listed — it is framework/runtime-managed
# (`next dev` → development, `next build` → production) and must not be set here.

# ── Shared ────────────────────────────────────────────────────────────────────
# local | test | production — local/test force the mock boundary adapters.
APP_MODE=local
# Origin the web/admin apps proxy /v1 + /api/auth to (the API). Portless named URL.
API_URL=https://api.docket.localhost
# Public origin of the product web app (sign-in + OAuth consent pages). The MCP OAuth
# defaults derive from it, so the authorization server works in every deploy by default.
WEB_URL=https://docket.localhost
# API listen port (required by the contract). In dev, portless assigns an ephemeral
# port and overrides this; the value here is the fallback for non-portless runs.
PORT=4000

# ── Database (required) ─────────────────────────────────────────────────────────
# Driver is chosen from the URL scheme: pglite: | postgres: | neon:
#   local dev : postgres://docket:docket@localhost:5433/docket  (Docker; `pnpm db:up`)
#   zero-svc  : pglite://.data/docket   (embedded, in-process — no Docker)
#   prod      : the Neon pooled URL
DATABASE_URL=postgres://docket:docket@localhost:5433/docket
# Unpooled string used for migrations (optional; falls back to DATABASE_URL).
DATABASE_URL_UNPOOLED=

# ── Auth (BETTER_AUTH_SECRET required, ≥32 chars: openssl rand -base64 32) ───────
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32-min-32-chars
BETTER_AUTH_URL=https://api.docket.localhost
BETTER_AUTH_TRUSTED_ORIGINS=https://docket.localhost,https://admin.docket.localhost
# Switches Better Auth to a dynamic, per-request base URL (derived from the request host via
# x-forwarded-host, validated against this allowlist) + proxy-header trust. This is REQUIRED here,
# not optional: the web (docket.localhost) and admin (admin.docket.localhost) apps each proxy
# /api/auth to the API, so auth must resolve its base to whichever frontend the browser is on —
# otherwise the OAuth redirect_uri + session cookie land on the wrong origin. Same mechanism serves
# preview deployments + custom domains in prod (add usedocket.app,*.vercel.app, etc.).
BETTER_AUTH_ALLOWED_HOSTS=docket.localhost,admin.docket.localhost,api.docket.localhost
# Parent domain to scope session cookies to, so sibling subdomains share one session. Required for
# the local oAuthProxy relay (the callback is handled on api.docket.localhost but the app runs on
# docket.localhost — a host-only cookie there would be invisible). Set to the registrable parent of
# your hosts (e.g. docket.localhost locally, usedocket.app in prod). Unset ⇒ host-only cookies.
BETTER_AUTH_COOKIE_DOMAIN=docket.localhost
# OAuth proxy (optional; for preview/branch deploys with unregisterable URLs). When BOTH are set,
# Better Auth's oAuthProxy routes social OAuth through the production host (the only callback URL
# registered with the provider). Leave blank locally — local registers its own callback and runs
# OAuth directly. OAUTH_PROXY_SECRET must be the SAME on prod + every preview. Set together or not.
OAUTH_PROXY_SECRET=
OAUTH_PROXY_PRODUCTION_URL=
BETTER_AUTH_PASSKEY_RP_ID=docket.localhost
BETTER_AUTH_PASSKEY_RP_NAME=Docket
# Browser-exposed copy of the passkey RP ID, inlined into the web/admin client bundles. MUST
# equal BETTER_AUTH_PASSKEY_RP_ID — the sign-in flow passes it to the WebAuthn Signal API
# (PublicKeyCredential.signalUnknownCredential) to prune server-deleted passkeys. No fallback.
NEXT_PUBLIC_PASSKEY_RP_ID=docket.localhost
# Social providers (optional) — absent/placeholder ⇒ provider is not mounted, UI hides it.
# Turnkey setup: run `pnpm integrations` to be walked through each provider (exact console
# URL + redirect URI) and have the keys written here (and to staging/prod secret stores).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub — a single GitHub App is the ONLY GitHub credential: it powers sign-in (user-to-server
# OAuth), the issue/PR connector, AND the real-time webhook firehose (POST /internal/ingest/github).
# There is no separate OAuth App. Create it at Settings → Developer settings → GitHub Apps
# (run `pnpm integrations` to be walked through it). Absent ⇒ GitHub connector uses the mock.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Private key as a SINGLE-LINE base64 PEM: `base64 -i app.private-key.pem | tr -d '\n'`
GITHUB_APP_PRIVATE_KEY=
# Webhook signing secret (verifies the firehose): `openssl rand -hex 24`
GITHUB_APP_WEBHOOK_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
# Slack — one shared Slack app (create it from infra/slack/docket-app-manifest.yaml at
# https://api.slack.com/apps → "Create New App" → "From a manifest"; `pnpm integrations` walks you through).
# Powers "Connect Slack" (user-token OAuth) + the Events API firehose (POST /internal/ingest/slack).
# All three come from the app's Basic Information page. Absent ⇒ Slack connect is unavailable.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Discord app public key (developer portal → General Information) — verifies the Ed25519
# signature on POST /internal/ingest/discord. Absent ⇒ the Discord observer falls back to the mock.
DISCORD_PUBLIC_KEY=
# Discord OAuth2 app (developer portal → OAuth2) — powers "Connect Discord" (identify scope), which
# links a Discord account so mentions of it route to the right user. Both required together, or neither.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Microsoft Entra (Outlook mail connector; dormant until set)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=

# ── Billing (Stripe) — BILLING_ENABLED required; =true also needs the key + a price ──
# Empty/placeholder values keep the mock InMemoryBillingGateway; supplying a real
# STRIPE_SECRET_KEY (outside APP_MODE=local/test) selects RealStripeGateway. The gateway
# resolves a DOCKET_PRICE_LOOKUP_* lookup key (or a STRIPE_PRICE_TEAM price id) to the
# price, runs the 14-day trial, and verifies webhooks with STRIPE_WEBHOOK_SECRET.
# Embedded Checkout is the default flow (rendered via NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY).
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
DOCKET_PRICE_LOOKUP_TEAM=
DOCKET_PRICE_LOOKUP_TEAM_ANNUAL=
STRIPE_PRICE_TEAM=
STRIPE_BILLING_PORTAL_CONFIG_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── MCP remote server (MCP_TASKS_ENABLED + MCP_CIMD_STRICT required) ──────────────
# The OAuth 2.1 AS/RS is ON in every deploy by default — the three mechanical URLs
# derive from the required base config (see packages/env/src/api.ts); set one ONLY
# to override its derivation:
#   MCP_ISSUER_URL      ⇒ API_URL
#   MCP_RESOURCE_URL    ⇒ ${API_URL}/mcp     (the canonical RS URI tokens are bound to)
#   OIDC_LOGIN_PAGE_URL ⇒ ${WEB_URL}/sign-in
# MCP_ALLOWED_ORIGINS is a SECURITY allowlist (browser Origins allowed to hit /mcp;
# DNS-rebinding guard) and is never derived. Browser-less clients send no Origin and
# always pass; list any browser-based MCP clients per environment.
MCP_ISSUER_URL=
MCP_RESOURCE_URL=
MCP_ALLOWED_ORIGINS=https://docket.localhost
OIDC_LOGIN_PAGE_URL=
MCP_TASKS_ENABLED=false
MCP_CIMD_TRUST_ALLOWLIST=
MCP_CIMD_STRICT=true
MCP_SESSION_STORE_URL=

# ── Agent runtime (optional) ──────────────────────────────────────────────────────
# The built-in Athena runtime drives a real Claude turn via the Anthropic Messages API.
# Set ANTHROPIC_API_KEY to a real key (sk-ant-...) to select RealProviderRuntime in prod;
# blank/placeholder keeps the deterministic MockAgentRuntime (and local/test always mock).
ANTHROPIC_API_KEY=

# ── Ops ──────────────────────────────────────────────────────────────────────────
CRON_SECRET=dev-cron-secret-please-change-me
SENTRY_DSN=
BLOB_READ_WRITE_TOKEN=
# Export bucket URL + token are all-or-nothing (optional).
EXPORT_BUCKET_URL=
EXPORT_BUCKET_TOKEN=

# ── Transactional email (SMTP) ────────────────────────────────────────────────────
# SmtpMailer (nodemailer). Absent/blank SMTP_HOST or MAIL_FROM ⇒ mock CaptureMailer.
#   local : SMTP_HOST=localhost SMTP_PORT=1025 (Mailpit; no auth) MAIL_FROM="Docket <dev@docket.localhost>"
#   prod  : your relay host/port + SMTP_USER/SMTP_PASS, SMTP_SECURE=true on port 465.
# SMTP_PORT defaults to 587 (STARTTLS); SMTP_SECURE defaults to true only on port 465.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ── Operator (staff) bootstrap — optional, dev-only ────────────────────────────────
# Breaks the admin chicken-and-egg (the only API that mints staff itself requires being a
# superadmin). In non-production, a signed-in user whose email is listed here is granted
# operator access on first /admin hit — this runs inside the API, the one path that works
# under embedded PGlite (a separate `pnpm db:seed:staff` CLI cannot open the DB while the
# API holds it). Comma-separated `email[:role]`; role ∈ support|finance|superadmin
# (default superadmin). Ignored entirely when APP_MODE=production.
STAFF_BOOTSTRAP_EMAILS=

# ── Connectors (GitHub / Linear / Drive / Gmail / Calendar) ─────────────────────────
# RealConnector talks to each provider's API with a per-connection OAuth token / API key
# supplied from the stored credential (NOT from env). These optional variables only
# override the provider API base for self-hosted / non-public hosts (e.g. GitHub
# Enterprise); blank ⇒ the provider's public API base is used.
GITHUB_API_BASE=
LINEAR_API_BASE=
GOOGLE_DRIVE_API_BASE=
GOOGLE_GMAIL_API_BASE=
MICROSOFT_GRAPH_API_BASE=
GOOGLE_CALENDAR_API_BASE=

# ── Public (browser; Next inlines these literally) ───────────────────────────────
NEXT_PUBLIC_API_URL=https://api.docket.localhost
NEXT_PUBLIC_APP_URL=https://docket.localhost
# Provider/connector availability and deploy mode are NOT browser flags: the client reads them
# from the server's `GET /v1/config`, derived from the real credentials above (a provider is
# offered iff its OAuth client id + secret are set). So there is nothing to mirror here — set the
# server creds and the buttons appear. (Passkey RP id below is still required client-side.)
