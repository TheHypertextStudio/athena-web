# Docket — committed LOCAL defaults (safe, non-secret). Runs the full product against
# mock boundary adapters (APP_MODE=local), so no external accounts are needed.
#
# This file is TRACKED but armed with `git update-index --skip-worktree` (run on
# `pnpm install`), so your local edits are NOT seen by git — add real keys here freely.
# See docs/local-development.md. The contract/source of truth is .env.example.
#
# Footgun: if this file changes upstream, `git pull` may refuse. Recover with:
#   git update-index --no-skip-worktree .env.local && git pull && (redo your edits)
#
# NODE_ENV is intentionally NOT set here — it is framework/runtime-managed and setting
# it would poison the production build.

# ── Shared ────────────────────────────────────────────────────────────────────
APP_MODE=local
API_URL=https://api.docket.localhost
# Portless overrides PORT with an ephemeral port in dev; fallback for non-portless runs.
PORT=4000

# ── Database ────────────────────────────────────────────────────────────────────
# Zero-service embedded Postgres (PGlite, in-process, on-disk under .data/) — no Docker
# daemon required, matching APP_MODE=local's "no external accounts" promise. Driver is
# chosen from the URL scheme (see packages/db/src/client.ts). To use the Docker Postgres
# instead: `pnpm db:up` then set DATABASE_URL=postgres://docket:docket@localhost:5433/docket.
DATABASE_URL=pglite://.data/docket
# Optional locally (migrations reuse DATABASE_URL).
DATABASE_URL_UNPOOLED=

# ── Auth ─────────────────────────────────────────────────────────────────────────
# Shared DEV-ONLY secret (≥32 chars). NOT for production — prod sets its own.
BETTER_AUTH_SECRET=dev-local-shared-secret-not-for-production-use-0000
BETTER_AUTH_URL=https://api.docket.localhost
BETTER_AUTH_TRUSTED_ORIGINS=https://web.docket.localhost,https://admin.docket.localhost,https://marketing.docket.localhost
BETTER_AUTH_PASSKEY_RP_ID=docket.localhost
BETTER_AUTH_PASSKEY_RP_NAME=Docket
# Social providers (optional) — empty ⇒ provider not mounted, UI hides it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# ── Billing (Stripe) — disabled locally ──────────────────────────────────────────
BILLING_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
DOCKET_PRICE_LOOKUP_TEAM=
DOCKET_PRICE_LOOKUP_TEAM_ANNUAL=
STRIPE_PRICE_TEAM=
STRIPE_BILLING_PORTAL_CONFIG_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── MCP remote server — disabled locally ─────────────────────────────────────────
MCP_ISSUER_URL=
MCP_RESOURCE_URL=
MCP_ALLOWED_ORIGINS=
OIDC_LOGIN_PAGE_URL=
MCP_TASKS_ENABLED=false
MCP_CIMD_TRUST_ALLOWLIST=
MCP_CIMD_STRICT=true
MCP_SESSION_STORE_URL=

# ── Agent runtime (optional) ─────────────────────────────────────────────────────
ATHENA_AGENT_ENDPOINT=
ATHENA_AGENT_API_KEY=
ANTHROPIC_API_KEY=

# ── Ops ──────────────────────────────────────────────────────────────────────────
CRON_SECRET=dev-cron-secret-please-change-me
SENTRY_DSN=
BLOB_READ_WRITE_TOKEN=
EXPORT_BUCKET_URL=
EXPORT_BUCKET_TOKEN=

# ── Public (browser; Next inlines these literally) ───────────────────────────────
NEXT_PUBLIC_API_URL=https://api.docket.localhost
NEXT_PUBLIC_APP_URL=https://web.docket.localhost
