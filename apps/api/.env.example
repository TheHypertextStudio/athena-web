# =============================================================================
# Project Athena API Server - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# See docs/engineering/deployment.md for complete setup guide

# =============================================================================
# CORE SETTINGS (Required)
# =============================================================================

# Node environment: development | production | test
NODE_ENV=development

# Server port
PORT=4000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# =============================================================================
# DATABASE (Required)
# =============================================================================

# PostgreSQL connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local development: postgresql://athena:athena_dev_password@localhost:5432/athena_dev
# Production: Use Cloud SQL connection string
DATABASE_URL=postgresql://athena:athena_dev_password@localhost:5432/athena_dev

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================

# Authentication secret key (minimum 32 characters)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-at-least-32-characters-long

# Public URL of the API server
BETTER_AUTH_URL=http://localhost:4000

# Frontend URL for CORS and redirects
FRONTEND_URL=http://localhost:3000

# =============================================================================
# GOOGLE OAUTH (Required - for auth and calendar sync)
# =============================================================================
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Required scopes: email, profile, openid, calendar.readonly, calendar.events
#
# IMPORTANT: Add BOTH redirect URIs to Google Console:
#   1. http://localhost:3000/api/auth/callback/google (user sign-in)
#   2. http://localhost:3000/settings/integrations/callback (calendar sync)
#
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/settings/integrations/callback

# =============================================================================
# OTHER OAUTH PROVIDERS (Optional)
# =============================================================================

# Apple OAuth
# Create credentials at: https://developer.apple.com/account/resources/authkeys
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Microsoft/Azure AD OAuth (also used for Outlook Calendar)
# Create credentials at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OUTLOOK_CALENDAR_REDIRECT_URI=

# iCloud Calendar (CalDAV)
# Uses app-specific password authentication - no config needed here

# =============================================================================
# INTEGRATION PROVIDERS (Optional)
# =============================================================================

# Linear Issue Tracker
# Create OAuth app at: https://linear.app/settings/api
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=
LINEAR_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/callback/linear
LINEAR_WEBHOOK_SECRET=

# GitHub
# Create OAuth app at: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/callback/github
GITHUB_WEBHOOK_SECRET=

# =============================================================================
# AI PROVIDERS (Optional - for Athena AI assistant)
# =============================================================================

# OpenAI API
# Get API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_ORGANIZATION_ID=

# Anthropic Claude API
# Get API key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Default AI provider: openai | anthropic
AI_DEFAULT_PROVIDER=openai

# =============================================================================
# EMAIL NOTIFICATIONS (Optional)
# =============================================================================

# Email provider: resend | smtp
EMAIL_PROVIDER=resend

# Resend API
# Get API key at: https://resend.com/api-keys
RESEND_API_KEY=

# Sender configuration
EMAIL_SENDER_ADDRESS=noreply@athena.app
EMAIL_SENDER_NAME=Project Athena

# SMTP configuration (if EMAIL_PROVIDER=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=

# =============================================================================
# SMS NOTIFICATIONS (Optional)
# =============================================================================

# SMS provider: twilio | vonage
SMS_PROVIDER=

# Twilio SMS
# Get credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# =============================================================================
# SLACK NOTIFICATIONS (Optional)
# =============================================================================

# Slack Incoming Webhook URL
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# =============================================================================
# PUSH NOTIFICATIONS (Optional)
# =============================================================================

# Web Push VAPID keys
# Generate with: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:push@athena.app

# Firebase Cloud Messaging (for mobile push)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# =============================================================================
# FILE STORAGE (Optional)
# =============================================================================

# Storage provider: local | s3
STORAGE_PROVIDER=local

# Local storage path (for development)
STORAGE_LOCAL_PATH=./uploads

# AWS S3 or S3-compatible storage (MinIO, GCS, etc.)
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT=                    # Optional: for S3-compatible services like MinIO

# Public URL base for serving uploaded files
STORAGE_PUBLIC_URL_BASE=

# Maximum file upload size in bytes (default: 10MB)
STORAGE_MAX_FILE_SIZE=10485760

# =============================================================================
# BILLING - STRIPE (Optional)
# =============================================================================

# Stripe API
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for subscription plans
STRIPE_PRICE_ID_PRO_MONTHLY=
STRIPE_PRICE_ID_PRO_YEARLY=
STRIPE_PRICE_ID_TEAM_MONTHLY=
STRIPE_PRICE_ID_TEAM_YEARLY=

# =============================================================================
# OBSERVABILITY (Optional - Production recommended)
# =============================================================================

# Sentry Error Tracking
# Get DSN at: https://sentry.io
SENTRY_DSN=

# =============================================================================
# RATE LIMITING (Optional)
# =============================================================================

# Rate limit window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Max requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100
