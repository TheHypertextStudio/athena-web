{
  "openapi": "3.1.0",
  "info": {
    "title": "Athena API",
    "version": "1.0.0",
    "description": "REST API for Project Athena - Personal productivity and task management"
  },
  "components": {
    "schemas": {
      "UnauthorizedError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "enum": ["Unauthorized"]
          },
          "message": {
            "type": "string",
            "default": "Authentication required"
          }
        },
        "required": ["error"]
      },
      "NotFoundError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "enum": ["Not found"]
          },
          "message": {
            "type": "string",
            "description": "Resource description"
          }
        },
        "required": ["error"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Error type or code"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message"
          },
          "details": {
            "type": "object",
            "additionalProperties": {},
            "description": "Additional error details"
          }
        },
        "required": ["error"]
      },
      "TaskResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/TaskWithRelations"
          }
        },
        "required": ["data"],
        "description": "Task response"
      },
      "TaskWithRelations": {
        "allOf": [
          {
            "$ref": "#/components/schemas/Task"
          },
          {
            "type": "object",
            "properties": {
              "project": {
                "type": ["object", "null"],
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "Project UUID"
                  },
                  "name": {
                    "type": "string",
                    "description": "Project name",
                    "example": "Website Redesign"
                  }
                },
                "required": ["id", "name"],
                "description": "Associated project details"
              },
              "assignee": {
                "type": ["object", "null"],
                "properties": {
                  "id": {
                    "type": "string",
                    "format": "uuid",
                    "description": "User UUID"
                  },
                  "name": {
                    "type": ["string", "null"],
                    "description": "User display name",
                    "example": "John Doe"
                  }
                },
                "required": ["id", "name"],
                "description": "Assigned user details"
              },
              "creator": {
                "$ref": "#/components/schemas/UserRef"
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "tag": {
                      "$ref": "#/components/schemas/TagRef"
                    }
                  },
                  "required": ["tag"]
                },
                "description": "Associated tags"
              }
            }
          }
        ]
      },
      "UserRef": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "User UUID"
          },
          "name": {
            "type": ["string", "null"],
            "description": "User display name",
            "example": "John Doe"
          }
        },
        "required": ["id", "name"],
        "description": "Creator user details"
      },
      "TagRef": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Tag UUID"
          },
          "name": {
            "type": "string",
            "description": "Tag name",
            "example": "Work"
          },
          "color": {
            "type": ["string", "null"],
            "description": "Tag color hex code",
            "example": "#3B82F6"
          }
        },
        "required": ["id", "name", "color"]
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Task UUID"
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "Task title",
            "example": "Review pull request"
          },
          "description": {
            "type": ["string", "null"],
            "description": "Task description",
            "example": "Review the authentication changes in PR #123"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "cancelled"],
            "description": "Task status",
            "example": "pending"
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high", "urgent"],
            "description": "Task priority level",
            "example": "medium"
          },
          "deadline": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Task deadline",
            "example": "2025-01-15T17:00:00Z"
          },
          "estimatedMinutes": {
            "type": ["integer", "null"],
            "exclusiveMinimum": 0,
            "description": "Estimated time to complete in minutes",
            "example": 30
          },
          "projectId": {
            "type": ["string", "null"],
            "format": "uuid",
            "description": "Associated project UUID"
          },
          "assigneeId": {
            "type": ["string", "null"],
            "format": "uuid",
            "description": "Assigned user UUID"
          },
          "creatorId": {
            "type": "string",
            "format": "uuid",
            "description": "Creator user UUID"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp",
            "example": "2025-01-09T12:00:00Z"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp",
            "example": "2025-01-09T12:00:00Z"
          }
        },
        "required": [
          "id",
          "title",
          "description",
          "status",
          "priority",
          "deadline",
          "estimatedMinutes",
          "projectId",
          "assigneeId",
          "creatorId",
          "createdAt",
          "updatedAt"
        ]
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "enum": ["Validation error"]
          },
          "details": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field": {
                  "type": "string",
                  "description": "Field that failed validation"
                },
                "message": {
                  "type": "string",
                  "description": "Validation error message"
                }
              },
              "required": ["field", "message"]
            }
          }
        },
        "required": ["error", "details"]
      },
      "CreateTaskRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "Task title",
            "example": "Review pull request"
          },
          "description": {
            "type": "string",
            "maxLength": 10000,
            "description": "Task description",
            "example": "Review the authentication changes in PR #123"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "cancelled"],
            "default": "pending",
            "description": "Initial task status",
            "example": "pending"
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high", "urgent"],
            "default": "medium",
            "description": "Task priority",
            "example": "medium"
          },
          "deadline": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Task deadline (ISO 8601)",
            "example": "2025-01-15T17:00:00Z"
          },
          "estimatedMinutes": {
            "type": "integer",
            "minimum": 0,
            "description": "Estimated time to complete in minutes",
            "example": 30
          },
          "projectId": {
            "type": "string",
            "format": "uuid",
            "description": "Associated project UUID"
          },
          "assigneeId": {
            "type": "string",
            "format": "uuid",
            "description": "Assigned user UUID"
          },
          "tagIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Tag UUIDs to associate with the task"
          }
        },
        "required": ["title"]
      },
      "TaskDependenciesResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Task"
            }
          },
          "total": {
            "type": "integer",
            "description": "Total number of items"
          }
        },
        "required": ["data"],
        "description": "Task dependencies response"
      },
      "TaskListResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaskWithRelations"
            }
          },
          "total": {
            "type": "integer",
            "description": "Total number of items"
          }
        },
        "required": ["data"],
        "description": "Task list response"
      },
      "UpdateTaskRequest": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "Task title",
            "example": "Review pull request"
          },
          "description": {
            "type": ["string", "null"],
            "maxLength": 10000,
            "description": "Task description (null to clear)"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "cancelled"],
            "description": "Task status",
            "example": "pending"
          },
          "priority": {
            "type": "string",
            "enum": ["low", "medium", "high", "urgent"],
            "description": "Task priority",
            "example": "medium"
          },
          "deadline": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "Task deadline (ISO 8601, null to clear)"
          },
          "estimatedMinutes": {
            "type": ["integer", "null"],
            "minimum": 0,
            "description": "Estimated time in minutes (null to clear)"
          },
          "projectId": {
            "type": ["string", "null"],
            "format": "uuid",
            "description": "Associated project UUID (null to clear)"
          },
          "assigneeId": {
            "type": ["string", "null"],
            "format": "uuid",
            "description": "Assigned user UUID (null to clear)"
          },
          "tagIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "description": "Tag UUIDs (replaces existing tags)"
          }
        }
      }
    },
    "parameters": {}
  },
  "paths": {
    "/api/tasks/{id}/tags/{tagId}": {
      "post": {
        "tags": ["Tasks"],
        "summary": "Add tag to task",
        "description": "Associate a tag with a task.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Task UUID"
            },
            "required": true,
            "description": "Task UUID",
            "name": "id",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Tag UUID"
            },
            "required": true,
            "description": "Tag UUID",
            "name": "tagId",
            "in": "path"
          }
        ],
        "responses": {
          "201": {
            "description": "Tag added to task successfully"
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedError"
                }
              }
            }
          },
          "404": {
            "description": "Task or tag not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Tasks"],
        "summary": "Remove tag from task",
        "description": "Remove a tag association from a task.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Task UUID"
            },
            "required": true,
            "description": "Task UUID",
            "name": "id",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Tag UUID"
            },
            "required": true,
            "description": "Tag UUID",
            "name": "tagId",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Tag removed from task successfully"
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedError"
                }
              }
            }
          },
          "404": {
            "description": "Task or tag not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          }
        }
      }
    },
    "/api/tasks/{id}/dependencies/{dependsOnId}": {
      "post": {
        "tags": ["Tasks"],
        "summary": "Add task dependency",
        "description": "Add a dependency relationship between two tasks.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Task UUID"
            },
            "required": true,
            "description": "Task UUID",
            "name": "id",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Dependency task UUID"
            },
            "required": true,
            "description": "Dependency task UUID",
            "name": "dependsOnId",
            "in": "path"
          }
        ],
        "responses": {
          "201": {
            "description": "Dependency added successfully"
          },
          "400": {
            "description": "Invalid dependency (e.g., circular dependency)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedError"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["Tasks"],
        "summary": "Remove task dependency",
        "description": "Remove a dependency relationship between two tasks.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Task UUID"
            },
            "required": true,
            "description": "Task UUID",
            "name": "id",
            "in": "path"
          },
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Dependency task UUID"
            },
            "required": true,
            "description": "Dependency task UUID",
            "name": "dependsOnId",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Dependency removed successfully"
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedError"
                }
              }
            }
          },
          "404": {
            "description": "Task or dependency not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          }
        }
      }
    },
    "/api/tasks/": {
      "post": {
        "tags": ["Tasks"],
        "summary": "Create a task",
        "description": "Create a new task.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Task created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedError"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Tasks"],
        "summary": "List tasks",
        "description": "Retrieve a list of tasks with optional filtering and pagination.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Filter by project"
            },
            "required": false,
            "description": "Filter by project",
            "name": "projectId",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": ["pending", "in_progress", "completed", "cancelled"],
              "description": "Filter by status",
              "example": "pending"
            },
            "required": false,
            "description": "Filter by status",
            "name": "status",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "enum": ["low", "medium", "high", "urgent"],
              "description": "Filter by priority",
              "example": "medium"
            },
            "required": false,
            "description": "Filter by priority",
            "name": "priority",
            "in": "query"
          },
          {
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 50,
              "description": "Maximum number of tasks to return",
              "example": 50
            },
            "required": false,
            "description": "Maximum number of tasks to return",
            "name": "limit",
            "in": "query"
          },
          {
            "schema": {
              "type": ["integer", "null"],
              "minimum": 0,
              "default": 0,
              "description": "Number of tasks to skip",
              "example": 0
            },
            "required": false,
            "description": "Number of tasks to skip",
            "name": "offset",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Tasks retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedError"
                }
              }
            }
          }
        }
      }
    },
    "/api/tasks/{id}": {
      "delete": {
        "tags": ["Tasks"],
        "summary": "Delete a task",
        "description": "Delete a task by its ID.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Task UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "description": "Task UUID",
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "204": {
            "description": "Task deleted successfully"
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedError"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": ["Tasks"],
        "summary": "Get a task",
        "description": "Retrieve a single task by its ID.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Task UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "description": "Task UUID",
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Task retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedError"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": ["Tasks"],
        "summary": "Update a task",
        "description": "Update an existing task. Only provided fields will be updated.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Task UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "description": "Task UUID",
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTaskRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Task updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationError"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedError"
                }
              }
            }
          },
          "404": {
            "description": "Task not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotFoundError"
                }
              }
            }
          }
        }
      }
    },
    "/api/tasks/{id}/dependencies": {
      "get": {
        "tags": ["Tasks"],
        "summary": "Get task dependencies",
        "description": "Retrieve all tasks that this task depends on.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "format": "uuid",
              "description": "Task UUID",
              "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "required": true,
            "description": "Task UUID",
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Dependencies retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskDependenciesResponse"
                }
              }
            }
          },
          "401": {
            "description": "Authentication required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UnauthorizedError"
                }
              }
            }
          },
