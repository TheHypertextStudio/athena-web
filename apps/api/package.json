{
  "name": "@docket/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "description": "Docket backend: authentication, the typed RPC API, billing and cron, and the MCP server.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "portless": {
    "name": "api.docket",
    "script": "dev:app"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "portless run --force",
    "dev:app": "tsx watch --include .env.local --import ./src/dev-env.ts src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@docket/auth": "workspace:*",
    "@docket/authz": "workspace:*",
    "@docket/boundaries": "workspace:*",
    "@docket/db": "workspace:*",
    "@docket/env": "workspace:*",
    "@docket/types": "workspace:*",
    "@hono/node-server": "^2.0.4",
    "@hono/standard-validator": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:",
    "@scalar/hono-api-reference": "catalog:",
    "drizzle-orm": "catalog:",
    "fflate": "^0.8.3",
    "hono": "catalog:",
    "hono-openapi": "catalog:",
    "tsx": "^4.22.4",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@docket/eslint-config": "workspace:*",
    "@docket/tsconfig": "workspace:*",
    "@dotenvx/dotenvx": "^1.75.1",
    "@standard-schema/spec": "^1.0.0",
    "@electric-sql/pglite": "catalog:",
    "@types/node": "25.9.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
