{
  "name": "@docket/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "description": "Docket backend: authentication, the typed RPC API, billing and cron, and the MCP server.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "portless": {
    "name": "api.docket",
    "script": "dev:app"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "portless",
    "dev:app": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@docket/auth": "workspace:*",
    "@docket/authz": "workspace:*",
    "@docket/boundaries": "workspace:*",
    "@docket/db": "workspace:*",
    "@docket/env": "workspace:*",
    "@docket/types": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "catalog:",
    "@scalar/hono-api-reference": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "hono-openapi": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@docket/eslint-config": "workspace:*",
    "@docket/tsconfig": "workspace:*",
    "@electric-sql/pglite": "catalog:",
    "@types/node": "24.13.0",
    "tsx": "^4.19.2",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
