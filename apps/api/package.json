{
  "name": "@athena/api",
  "version": "0.0.0",
  "private": true,
  "description": "Athena API backend service",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@athena/mcp-server": "workspace:*",
    "@athena/shared": "workspace:*",
    "@athena/types": "workspace:*",
    "@better-auth/passkey": "^1.4.10",
    "@hono/node-server": "^1.19.7",
    "@hono/zod-openapi": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@types/web-push": "^3.6.4",
    "better-auth": "^1.4.10",
    "drizzle-orm": "^0.45.1",
    "google-auth-library": "^9.15.1",
    "hono": "^4.11.3",
    "jose": "^6.0.11",
    "openai": "^6.15.0",
    "pino": "^10.1.0",
    "postgres": "^3.4.8",
    "resend": "^6.6.0",
    "rrule": "^2.8.1",
    "stripe": "^20.1.1",
    "web-push": "^3.6.7",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@athena/test-utils": "workspace:*",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "drizzle-kit": "^0.31.8",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
