{
  "extends": ["//"],
  // The Hono API validates the full server env contract (`@docket/env/api`) when it boots, so
  // its long-running `dev` server needs every server-var group made available under strict mode.
  // These live here — not in the root globalEnv — so they only invalidate API caches, never the
  // Next apps'. `build` is `tsc` (no runtime env) and `test` sets its own env, so neither needs them.
  "tasks": {
    "dev": {
      "env": [
        "WEB_URL",
        "BETTER_AUTH_*",
        "OAUTH_PROXY_*",
        "GOOGLE_*",
        "GITHUB_*",
        "LINEAR_*",
        "SLACK_SIGNING_SECRET",
        "MCP_*",
        "OIDC_*",
        "STRIPE_*",
        "DOCKET_PRICE_*",
        "ATHENA_*",
        "ANTHROPIC_API_KEY",
        "CRON_SECRET",
        "SENTRY_DSN",
        "BLOB_READ_WRITE_TOKEN",
        "EXPORT_BUCKET_*",
        "BILLING_ENABLED",
        "SMTP_*",
        "RESEND_API_KEY",
        "MAIL_FROM",
        "STAFF_BOOTSTRAP_EMAILS"
      ]
    }
  }
}
