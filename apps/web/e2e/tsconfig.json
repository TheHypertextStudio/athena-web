{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@docket/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["@playwright/test", "node"],
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "composite": false,
    "incremental": false
  },
  "include": ["**/*.ts"]
}
