{
  "name": "@docket/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Docket - workflow platform monorepo",
  "repository": {
    "type": "git",
    "url": "https://github.com/hypertext-studio/athena-service.git"
  },
  "license": "UNLICENSED",
  "scripts": {
    "build": "dotenv -e .env.local -- turbo run build",
    "dev": "dotenv -e .env.local -- turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "env:check": "tsx scripts/env-check.ts",
    "proxy:install": "portless service install",
    "proxy:status": "portless service status",
    "proxy:uninstall": "portless service uninstall",
    "db:up": "docker compose up -d --wait postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && pnpm db:migrate",
    "db:generate": "dotenv -e .env.local -- turbo run db:generate --filter=@docket/db",
    "db:migrate": "dotenv -e .env.local -- turbo run db:migrate --filter=@docket/db",
    "db:studio": "dotenv -e .env.local -- turbo run db:studio --filter=@docket/db",
    "db:auth:generate": "dotenv -e .env.local -- turbo run db:auth:generate --filter=@docket/db",
    "prepare": "husky && (git update-index --skip-worktree .env.local 2>/dev/null || true)"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.17.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "24.13.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.8",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.17.0",
    "portless": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "semantic-release": "^24.2.0",
    "tsx": "^4.19.2",
    "turbo": "^2.9.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.18.2",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11.0.0"
  }
}
