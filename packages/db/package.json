{
  "name": "@docket/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "description": "Docket data layer — Drizzle schema, database client, migrations, and ULID id generation.",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:auth:generate": "echo 'auth schema is hand-authored in src/schema/auth.ts; the P6 auth lane regenerates it with the full Better Auth plugin set'",
    "clean": "rm -rf .turbo *.tsbuildinfo",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@docket/env": "workspace:*",
    "@docket/types": "workspace:*",
    "@electric-sql/pglite": "catalog:",
    "@neondatabase/serverless": "catalog:",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:",
    "ulid": "catalog:"
  },
  "devDependencies": {
    "@docket/eslint-config": "workspace:*",
    "@docket/tsconfig": "workspace:*",
    "@types/node": "25.9.2",
    "drizzle-kit": "catalog:",
    "tsx": "^4.22.4",
    "vitest": "^4.1.8"
  }
}
