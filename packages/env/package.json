{
  "name": "@docket/env",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "description": "Docket validated, fail-fast environment configuration, per app surface.",
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/api.ts",
    "./web": "./src/web.ts",
    "./admin": "./src/admin.ts",
    "./registry": "./src/registry.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf .turbo *.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@t3-oss/env-core": "catalog:",
    "@t3-oss/env-nextjs": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@docket/eslint-config": "workspace:*",
    "@docket/tsconfig": "workspace:*",
    "@types/node": "25.9.2"
  }
}
