{
  "name": "@docket/test-utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "description": "Shared testing utilities — tenant and session-seed helpers, plus the documentation-coverage harness.",
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo *.tsbuildinfo",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@docket/db": "workspace:*",
    "@docket/types": "workspace:*",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@docket/eslint-config": "workspace:*",
    "@docket/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
