{
  "$schema": "https://v2-9-18.turborepo.dev/schema.json",
  "ui": "tui",
  "envMode": "strict",
  "globalEnv": [
    "NODE_ENV",
    "APP_MODE",
    "CI",
    "PORT",
    "API_URL",
    "SKIP_ENV_VALIDATION",
    "CRON_SECRET",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "BETTER_AUTH_*",
    "STRIPE_*",
    "DOCKET_PRICE_*",
    "MCP_*",
    "OIDC_*",
    "GOOGLE_*",
    "GITHUB_*",
    "LINEAR_*",
    "ATHENA_*",
    "ANTHROPIC_API_KEY",
    "SENTRY_DSN",
    "BLOB_READ_WRITE_TOKEN",
    "EXPORT_BUCKET_*",
    "NEXT_PUBLIC_*",
    "BILLING_ENABLED"
  ],
  "globalPassThroughEnv": ["VERCEL", "VERCEL_*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "NODE_ENV",
        "API_URL",
        "DATABASE_URL",
        "DATABASE_URL_UNPOOLED",
        "BETTER_AUTH_*",
        "STRIPE_*",
        "DOCKET_PRICE_*",
        "MCP_*",
        "OIDC_*",
        "GOOGLE_*",
        "GITHUB_*",
        "LINEAR_*",
        "ATHENA_*",
        "ANTHROPIC_API_KEY",
        "CRON_SECRET",
        "SENTRY_DSN",
        "BLOB_READ_WRITE_TOKEN",
        "EXPORT_BUCKET_*",
        "NEXT_PUBLIC_*",
        "BILLING_ENABLED"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      // Bring the DB up and migrated before any app server starts, natively via the task
      // graph: dev → (^)db:migrate → //#db:up. Apps that don't depend on @docket/db
      // (marketing) simply skip it. Replaces the old `db:up && db:migrate &&` shell chain.
      "dependsOn": ["^db:migrate"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint:fix": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "env": ["NODE_ENV", "DATABASE_URL", "DATABASE_URL_UNPOOLED", "SKIP_ENV_VALIDATION"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": ["playwright-report/**", "test-results/**"],
      "env": ["NODE_ENV", "API_URL", "NEXT_PUBLIC_*", "DATABASE_URL", "DATABASE_URL_UNPOOLED"]
    },
    "clean": {
      "cache": false
    },
    // Root task (runs the root `db:up` script, which is scheme-aware: it starts + waits on
    // the Docker Postgres for a `postgres:`/`neon:` DATABASE_URL, and is a no-op for the
    // embedded `pglite:` mode). db:migrate depends on it, so a TCP DB is healthy before
    // migrations run, while the zero-service PGlite mode needs no daemon.
    "//#db:up": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:generate": {
      "cache": false,
      "env": ["DATABASE_URL", "DATABASE_URL_UNPOOLED"]
    },
    "db:migrate": {
      "cache": false,
      "dependsOn": ["//#db:up"],
      "env": ["DATABASE_URL", "DATABASE_URL_UNPOOLED"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true,
      "env": ["DATABASE_URL", "DATABASE_URL_UNPOOLED"]
    },
    "db:auth:generate": {
      "cache": false,
      "env": ["DATABASE_URL", "DATABASE_URL_UNPOOLED", "BETTER_AUTH_*"]
    }
  }
}
