{
  "$schema": "https://v2-10-2.turborepo.dev/schema.json",
  "ui": "tui",
  "envMode": "strict",
  // Only TRULY cross-cutting vars live here (they bust every task's cache). App/service-specific
  // groups (BETTER_AUTH_*, STRIPE_*, MCP_*, GOOGLE_*, …) are declared in the consuming package's
  // turbo.json instead, so e.g. rotating a Stripe key no longer invalidates the web/admin caches.
  "globalEnv": [
    "NODE_ENV",
    "APP_MODE",
    "CI",
    "PORT",
    "API_URL",
    "SKIP_ENV_VALIDATION",
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED"
  ],
  "globalPassThroughEnv": ["VERCEL", "VERCEL_*", "BETTER_AUTH_*", "GOOGLE_*"],
  // Remote cache is signed (HMAC over artifacts). Inert until a cache is configured: with no
  // TURBO_TOKEN/TURBO_API set, turbo silently uses the local cache only. CI supplies the token +
  // TURBO_REMOTE_CACHE_SIGNATURE_KEY from secrets — see .github/workflows/ci.yml.
  "remoteCache": { "signature": true },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      // Docs-only edits never change build output — keep them out of the cache key.
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      // Bring the DB up and migrated before any app server starts, natively via the task
      // graph: dev → (^)db:migrate → //#db:up. Apps that don't depend on @docket/db
      // (marketing) simply skip it. Replaces the old `db:up && db:migrate &&` shell chain.
      "dependsOn": ["^db:migrate"]
    },
    // lint/typecheck/test no longer depend on `^build`: workspace packages expose raw TS
    // (`"types": "./src/index.ts"`), so tsc/eslint/vitest resolve dependency source directly —
    // building deps first was pure overhead in CI.
    "lint": {
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"]
    },
    "lint:fix": {
      "outputs": []
    },
    "typecheck": {
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"]
    },
    "test": {
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": ["playwright-report/**", "test-results/**"],
      "env": ["NEXT_PUBLIC_*"]
    },
    "clean": {
      "cache": false
    },
    // Root task (runs the root `db:up` script, which is scheme-aware: it starts + waits on
    // the Docker Postgres for a `postgres:`/`neon:` DATABASE_URL, and is a no-op for the
    // embedded `pglite:` mode). db:migrate depends on it, so a TCP DB is healthy before
    // migrations run, while the zero-service PGlite mode needs no daemon.
    "//#db:up": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "dependsOn": ["//#db:up"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:auth:generate": {
      "cache": false
    }
  }
}
